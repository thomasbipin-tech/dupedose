# ── DupeDose environment ──────────────────────────────────────
# Copy to .env.local and fill in. EVERYTHING is optional during early
# development: with no values set, the site runs on in-memory seed data
# (src/lib/data.ts), the dupe engine uses rule-based scoring, and
# affiliate links fall back to plain retailer URLs.

# Supabase (Postgres + storage). Without these, db.ts uses seed fixtures.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server/scripts only — never expose to the client

# Claude matching engine. Without this, the rule-based scorer is used.
ANTHROPIC_API_KEY=

# Affiliate IDs. Without these, "View Deal" links go to raw retailer URLs.
AMAZON_ASSOC_TAG=                 # e.g. dupedose-20
SKIMLINKS_ID=                     # e.g. 123456X7654321

# Guards the scheduled price-refresh route (/api/cron/refresh).
CRON_SECRET=
